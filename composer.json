{
  "name": "appswithlove/statamic-extended-section",
  "license": "MIT",
  "type": "statamic-addon",
  "description": "Extended sections for statamic",
  "autoload": {
    "psr-4": {
      "AppsWithLove\\Statamic\\ExtendedSection\\": "src"
    }
  },
  "authors": [
    {
      "name": "Rémy Böhler"
    }
  ],
  "require": {
    "statamic/cms": "^6.0"
  },
  "extra": {
    "statamic": {
      "name": "Extended section",
      "description": "Fancy sections"
    },
    "laravel": {
      "providers": [
        "AppsWithLove\\Statamic\\ExtendedSection\\ServiceProvider"
      ]
    }
  },
  "require-dev": {
    "laravel/pint": "^1.18"
  },
  "config": {
    "allow-plugins": {
      "pixelfear/composer-dist-plugin": true
    }
  }
}
